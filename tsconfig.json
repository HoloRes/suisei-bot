{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"typeRoots": [
			"./src/lib/types",
			"./node_modules/@types"
		],
		"resolveJsonModule": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"importHelpers": true,
		"strict": true,
		"strictNullChecks": true,
	},
	"include": [
		"./src/**/*",
		"./prisma.config.ts"
	],
	"extends": "@tsconfig/node24/tsconfig.json"
}
